<style>
footer {
  border-top: var(--wire);
  padding: 2.5rem 0;
  margin-top: auto;
}

.inner {
  display: grid;
  grid-template-columns: 2fr 1fr 1fr 1fr;
  gap: 2rem;
  align-items: start;
}

.label {
  display: block;
  margin-bottom: 0.75rem;
}

.logo-text {
  display: block;
  font-size: 0.85rem;
  font-weight: 600;
  letter-spacing: 0.1em;
  margin-bottom: 0.6rem;
}

nav, .links {
  display: flex;
  flex-direction: column;
  gap: 0.4rem;
}

nav a, .links a {
  font-family: var(--font-mono);
  font-size: 0.72rem;
  letter-spacing: 0.08em;
  color: var(--muted);
  transition: color 0.15s;
}

nav a:hover, .links a:hover {
  color: var(--fg);
}

.small {
  font-size: 0.72rem;
  line-height: 1.75;
}

.right {
  text-align: right;
  display: flex;
  flex-direction: column;
  gap: 0.4rem;
}

@media (max-width: 768px) {
  .inner {
    grid-template-columns: 1fr 1fr;
    row-gap: 2rem;
  }
  .right { text-align: left; }
}

@media (max-width: 480px) {
  .inner { grid-template-columns: 1fr; }
}
</style>
