---
interface Props {
  slug:     string;
  title:    string;
  platform: string;
  status:   string;
  date:     string;
  summary:  string;
  tags:     string[];
}

const { slug, title, platform, status, date, summary, tags } = Astro.props;

const statusColors: Record<string, string> = {
  PRODUCTION:  '#2C7E50',
  TESTING:     '#D4840C',
  DEVELOPMENT: '#1F4B8A',
  PROTOTYPE:   '#7C7268',
};
const statusColor = statusColors[status] ?? '#7C7268';
---

<a href={`/projects/${slug}`} class="card">
  <div class="card-top">
    <span class="label">{platform}</span>
    <span class="mono status-badge" style={`color: ${statusColor}`}>{status}</span>
  </div>

  <h3>{title}</h3>
  <p class="summary">{summary}</p>

  <div class="card-bottom">
    <span class="label">{date}</span>
    <span class="mono arrow">→</span>
  </div>
</a>

<style>
.card {
  display: flex;
  flex-direction: column;
  gap: 0.75rem;
  padding: 1.5rem;
  border: 1px solid var(--border);
  color: inherit;
  text-decoration: none;
  transition: background 0.15s;
}

.card:hover {
  background: rgba(212, 132, 12, 0.06);
}

.card-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.status-badge {
  font-size: 0.65rem;
  letter-spacing: 0.1em;
}

h3 {
  font-size: 0.95rem;
  font-weight: 600;
  letter-spacing: 0.01em;
}

.summary {
  font-size: 0.82rem;
  color: var(--muted);
  line-height: 1.65;
  flex: 1;
}

.card-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-top: 1px solid var(--border-light);
  padding-top: 0.75rem;
  margin-top: 0.25rem;
}

.arrow {
  font-size: 0.85rem;
  transition: transform 0.15s;
}

.card:hover .arrow {
  transform: translateX(4px);
}
</style>
